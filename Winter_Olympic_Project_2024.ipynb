    }
   ],
   "source": [
    "# Graphing top sports over the 21st century\n",
    "\n",
    "ax_sport = sport_trend[top_sports].plot(\n",
    "        figsize=(10,6),\n",
    "        title='Top Sports Trends Over Time'\n",
    "        )\n",
    "\n",
    "ax_sport.set_xticks(sport_trend.index)   \n",
