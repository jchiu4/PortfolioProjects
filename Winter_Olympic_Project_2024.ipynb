    }
   ],
   "source": [
    "# Plotting top 3 sports for top countries\n",
    "\n",
    "plt.figure(figsize=(12,6))\n",
    "sns.barplot(\n",
    "    data=top_sports_per_country,\n",
    "    x='Country',\n",
    "    y='Medal_Count',\n",
    "    hue='Sport'\n",
    ")\n",
    "\n",
    "plt.title('Top Sports by Top Countries')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "be87b801-96a2-4ead-a58a-29bfbb33410e",
   "metadata": {},
   "source": [
    "## Do countries dominate because they’re strong, or because they focus on high-opportunity sports?"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "1b4ea64f-194a-4c83-9598-77468cc0a228",
   "metadata": {},
   "source": []
  },
  {
   "cell_type": "code",
   "execution_count": 30,
   "id": "688f7d83-a0a6-4dc1-9434-17d88273f8bb",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Calculate sport population based on participation (size)\n",
    "\n",
    "sport_popularity = df.groupby('Sport').size()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 31,
   "id": "f8c1d3bc-3be5-4283-9623-b099aa1be729",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Created new df to display only rows with Gold winnings\n",
    "\n",
    "df_gold = df[df['Medal'] == 'Gold']"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 32,
   "id": "47c53899-5c03-44ef-ba60-337276f09b79",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Calculate country gold dominance (gold count) per sport\n",
    "\n",
    "country_sport_gold = (\n",
    "    df_gold.groupby(['Country', 'Sport'])\n",
    "    .size()\n",
    "    .reset_index(name='Gold_Count')\n",
    ")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 33,
   "id": "2c76780b-1777-40a9-88a8-172133297db6",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Total game count from each sport\n",
    "\n",
    "sport_total = df.groupby('Sport').size()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 34,
   "id": "47b3f96c-1fa0-4a29-92a7-c02fc712bf6b",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Normalizing data: calculating gold ratio by (country gold wins)/(total game from each sport)\n",
    "\n",
    "country_sport_gold['Gold_Share'] = country_sport_gold.apply(\n",
    "    lambda row: row['Gold_Count'] / sport_total[row['Sport']],\n",
    "    axis=1\n",
    ")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 35,
   "id": "fc430986-926f-4d8f-9056-7f3d8f25da65",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Mapping Sport with its popularity\n",
    "\n",
    "merged = country_sport_gold.copy()\n",
    "merged['Sport_Popularity'] = merged['Sport'].map(sport_popularity)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 36,
   "id": "40b63ac2-0e60-43ec-9043-d71cffbb4ef0",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "-0.30411700112138257\n"
     ]
    }
   ],
   "source": [
    "# Calculating correlation between sport popularity and gold share\n",
    "\n",
    "corr = merged['Sport_Popularity'].corr(merged['Gold_Share'], method='pearson')\n",
    "print(corr)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 37,
   "id": "a717fb69-a172-4a4c-a024-aba173da971b",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 640x480 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "# Scatter plot sport populatiry vs gold share\n",
    "\n",
    "plt.scatter(\n",
    "    data=merged,\n",
    "    x='Sport_Popularity',\n",
    "    y='Gold_Share',\n",
    ")\n",
    "plt.title('Sport Popularity vs Gold Share')\n",
    "plt.xlabel('Sport Popularity')\n",
    "plt.ylabel('Gold Share')\n",
    "plt.show()\n"
   ]
  },
