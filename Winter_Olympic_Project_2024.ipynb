       "Snowboard               144\n",
       "Name: count, dtype: int64"
      ]
     },
     "execution_count": 23,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "df['Sport'].value_counts().head(5)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 24,
   "id": "74871026-41c4-4827-96d4-2fdf6263fe27",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Creating dataframe for top participated sports from each year\n",
    "\n",
    "sport_trend = df.groupby(['Year', 'Sport']).size().unstack().fillna(0)\n",
    "top_sports = df['Sport'].value_counts().head(5).index"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 25,
   "id": "eba96bce-d842-4104-a494-bf50b08b954c",
   "metadata": {},
   "outputs": [
    {
     "data": {
