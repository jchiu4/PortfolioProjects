     "output_type": "display_data"
    }
   ],
   "source": [
    "# Plot sport populatiry vs gold share using seaborn \n",
    "# Adds a regression line\n",
    "\n",
    "sns.regplot(x='Sport_Popularity', y='Gold_Share', data=merged, scatter_kws={\"color\": \"red\"}, line_kws={\"color\": \"blue\"})"
